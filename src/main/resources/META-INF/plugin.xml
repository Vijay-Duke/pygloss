<?xml version="1.0" encoding="UTF-8"?>
<idea-plugin>
    <id>dev.pytoenglish</id>
    <name>py-to-english</name>
    <version>0.1.0</version>
    <vendor email="dev@pytoenglish.dev">py-to-english</vendor>

    <description><![CDATA[
        English-over-Python reader plugin. Renders deterministic English annotations
        over Python source without modifying the file.
    ]]></description>

    <!-- Hard dependency on the Python module (always present in PyCharm) -->
    <depends>com.intellij.modules.python</depends>

    <!-- Optional dependency on PythonCore plugin for more precise integrations;
         without it, features degrade gracefully via python-features.xml. -->
    <depends optional="true" config-file="python-features.xml">PythonCore</depends>

    <extensions defaultExtensionNs="com.intellij">
        <applicationConfigurable
            parentId="tools"
            instance="dev.pytoenglish.settings.PyEnglishConfigurable"
            id="dev.pytoenglish.settings"
            displayName="py-to-english"/>
        <lang.foldingBuilder language="Python" implementationClass="dev.pytoenglish.render.PyEnglishFoldingBuilder"/>
        <toolWindow id="py-to-english" anchor="right" factoryClass="dev.pytoenglish.render.OutlineToolWindowFactory"/>
    </extensions>
</idea-plugin>
