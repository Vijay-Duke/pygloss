<?xml version="1.0" encoding="UTF-8"?>
<idea-plugin>
    <id>dev.pygloss</id>
    <name>PyGloss</name>
    <version>0.1.1</version>
    <vendor email="Mail@VijayIyengar.com" url="https://github.com/Vijay-Duke">Vijay Iyengar</vendor>

    <description><![CDATA[
        <p>Read unfamiliar Python without rewriting it.</p>
        <p>PyGloss adds a linked explanation layer directly inside the PyCharm editor using
        folds, inlays, and reader views. Its offline Polyglot Lens maps
        Python idioms to concepts from JavaScript, Java, Go, or C#. Optional Intent
        Summaries use your configured OpenAI-compatible or Anthropic endpoint.</p>
        <p>Your source files remain unchanged. AI features are opt-in and provider
        credentials are stored in the IDE password store.</p>
    ]]></description>

    <change-notes><![CDATA[
        <p><strong>0.1.1</strong> — Editor-only update.</p>
        <ul>
            <li>Removed the separate PyGloss tool window; explanations now stay in the editor.</li>
        </ul>
        <p><strong>0.1.0</strong> — Initial public release.</p>
        <ul>
            <li>Offline Polyglot Lens for common Python concepts.</li>
            <li>Code, Hints, Outline, and Reader viewing presets.</li>
            <li>Optional provider-backed intent summaries and line translations.</li>
            <li>Editor-only folds and inlays that leave more room for source code.</li>
        </ul>
    ]]></change-notes>

    <!-- Hard dependency on the Python module (always present in PyCharm) -->
    <depends>com.intellij.modules.python</depends>

    <!-- Optional dependency on PythonCore plugin for more precise integrations;
         without it, features degrade gracefully via python-features.xml. -->
    <depends optional="true" config-file="python-features.xml">PythonCore</depends>

    <extensions defaultExtensionNs="com.intellij">
        <applicationConfigurable
            parentId="tools"
            instance="dev.pygloss.render.config.PyGlossConfigurable"
            id="dev.pygloss.settings"
            displayName="PyGloss"/>
        <projectConfigurable
            parentId="dev.pygloss.settings"
            instance="dev.pygloss.render.config.PyGlossSummaryConfigurable"
            id="dev.pygloss.settings.summaries"
            displayName="Summaries"/>
        <lang.foldingBuilder language="Python" implementationClass="dev.pygloss.render.PyGlossFoldingBuilder"/>
        <codeInsight.declarativeInlayProvider
            language="Python"
            implementationClass="dev.pygloss.render.PyGlossInlayProvider"
            providerId="dev.pygloss.conceptCallouts"
            group="CODE_VISION_GROUP_NEW"
            bundle="messages.PyGlossBundle"
            nameKey="inlay.conceptCallouts.name"
            descriptionKey="inlay.conceptCallouts.description"
            isEnabledByDefault="true"/>
        <codeInsight.inlayProvider language="Python" implementationClass="dev.pygloss.render.BlockInlayFallbackProvider"/>
        <statusBarWidgetFactory
            id="dev.pygloss.intentSummaryStatus"
            implementation="dev.pygloss.render.IntentSummaryStatusWidgetFactory"/>
        <notificationGroup id="dev.pygloss.notifications" displayType="BALLOON"/>
        <postStartupActivity implementation="dev.pygloss.render.PyGlossFirstRunActivity"/>
    </extensions>

    <projectListeners>
        <listener
            class="dev.pygloss.render.ReaderUiEventListener"
            topic="dev.pygloss.application.ReaderUiEvents"/>
    </projectListeners>

    <actions>
        <action
            id="dev.pygloss.regenerate"
            class="dev.pygloss.actions.RegenerateAction"
            text="Regenerate English Summary"
            description="Re-asks the LLM for the PyGloss summary of the block at the caret.">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
        <group
            id="dev.pygloss.presets"
            class="com.intellij.openapi.actionSystem.DefaultActionGroup"
            text="PyGloss View"
            popup="true">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
            <action
                id="dev.pygloss.preset.code"
                class="dev.pygloss.actions.CodePresetAction"
                text="Code"
                description="Show source-first PyGloss output"/>
            <action
                id="dev.pygloss.preset.hints"
                class="dev.pygloss.actions.HintsPresetAction"
                text="Hints"
                description="Show concise PyGloss hints"/>
            <action
                id="dev.pygloss.preset.outline"
                class="dev.pygloss.actions.OutlinePresetAction"
                text="Outline"
                description="Show structural PyGloss hints in the editor"/>
            <action
                id="dev.pygloss.preset.reader"
                class="dev.pygloss.actions.ReaderPresetAction"
                text="Reader"
                description="Show detailed PyGloss reader output"/>
        </group>
    </actions>
</idea-plugin>
